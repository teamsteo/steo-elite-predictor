{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=600" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=verify-evening",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=verify-morning",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=verify-night",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/generate-daily?secret=secretsteo-elitecron2026",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=update-fundamentals",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=telegram-summary",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=telegram-valuebets",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/tennis-auto-publish?secret=secretsteo-elitecron2026&mode=major",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/tennis-auto-publish?secret=secretsteo-elitecron2026&mode=summary",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=telegram-summary",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=telegram-kamikaze",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/tennis-auto-publish?secret=secretsteo-elitecron2026&mode=valuebets",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=telegram-summary",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron?secret=secretsteo-elitecron2026&action=telegram-valuebets",
      "schedule": "0 19 * * *"
    }
  ]
}
