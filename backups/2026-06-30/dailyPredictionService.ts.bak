// ============================================
// FALLBACK - Prédictions simples (si ML échoue)
// ============================================

function createSimpleFootballPrediction(event: any, home: any, away: any): DailyPrediction | null {
  const homeTeam = home.team?.displayName || 'Unknown';
  const awayTeam = away.team?.displayName || 'Unknown';
  
  const homeRecord = home.records?.find((r: any) => r.type === 'total');
  const awayRecord = away.records?.find((r: any) => r.type === 'total');
  const homeWins = homeRecord?.wins || 0;
  const awayWins = awayRecord?.wins || 0;
  
  const totalWins = homeWins + awayWins;
  const homeProb = totalWins > 0 ? (homeWins / totalWins) * 100 : 50;
  const adjustedProb = Math.min(75, Math.max(25, homeProb + 10));
  const riskPercentage = 100 - adjustedProb;
  
  return {
    id: `fb_${event.id}`,
    sport: 'football',
    league: event.league?.name || 'Football',
    homeTeam,
    awayTeam,
    date: event.date,
    oddsHome: 1.85,
    oddsAway: 1.85,
    oddsDraw: 3.3,
    recommendation: adjustedProb > 50 ? homeTeam : awayTeam,
    predictedResult: adjustedProb > 50 ? 'home' : 'away',
    winProbability: Math.round(adjustedProb > 50 ? adjustedProb : 100 - adjustedProb),
    confidence: getConfidenceFromProb(adjustedProb > 50 ? adjustedProb : 100 - adjustedProb),
    riskPercentage: Math.round(riskPercentage),
    riskLevel: getRiskLevel(riskPercentage),
    valueBet: false,
    reasons: [`Match ${homeTeam} vs ${awayTeam}`, '⚠️ Fallback (ML non disponible)'],
    warnings: ['Prédiction simplifiée'],
    source: 'espn-fallback',
    modelVersion: 'football-simple-v1.0',
    generatedAt: new Date().toISOString(),
  };
}

function createSimpleBasketballPrediction(event: any, home: any, away: any): DailyPrediction | null {
  const homeTeam = home.team?.displayName || 'Unknown';
  const awayTeam = away.team?.displayName || 'Unknown';
  
  const homeRecord = home.records?.find((r: any) => r.type === 'total');
  const awayRecord = away.records?.find((r: any) => r.type === 'total');
  const homeWins = homeRecord?.wins || 0;
  const homeLosses = homeRecord?.losses || 0;
  const awayWins = awayRecord?.wins || 0;
  const awayLosses = awayRecord?.losses || 0;
  
  const homeWinRate = homeWins / (homeWins + homeLosses) || 0.5;
  const awayWinRate = awayWins / (awayWins + awayLosses) || 0.5;
  const homeProb = (homeWinRate * 0.6 + (1 - awayWinRate) * 0.4) * 100 + 10;
  const adjustedProb = Math.min(75, Math.max(25, homeProb));
  const riskPercentage = 100 - adjustedProb;
  
  return {
    id: `nba_${event.id}`,
    sport: 'basketball',
    league: 'NBA',
    homeTeam,
    awayTeam,
    date: event.date,
    oddsHome: 1.85,
    oddsAway: 1.85,
    recommendation: adjustedProb > 50 ? homeTeam : awayTeam,
    predictedResult: adjustedProb > 50 ? 'home' : 'away',
    winProbability: Math.round(adjustedProb > 50 ? adjustedProb : 100 - adjustedProb),
    confidence: getConfidenceFromProb(adjustedProb > 50 ? adjustedProb : 100 - adjustedProb),
    riskPercentage: Math.round(riskPercentage),
    riskLevel: getRiskLevel(riskPercentage),
    valueBet: false,
    reasons: [`${homeTeam}: ${homeWins}W-${homeLosses}L`, `${awayTeam}: ${awayWins}W-${awayLosses}L`, '⚠️ Fallback'],
    warnings: ['Prédiction simplifiée'],
    source: 'espn-fallback',
    modelVersion: 'nba-simple-v1.0',
    generatedAt: new Date().toISOString(),
  };
}

function createSimpleHockeyPrediction(event: any, home: any, away: any): DailyPrediction | null {
  const homeTeam = home.team?.displayName || 'Unknown';
  const awayTeam = away.team?.displayName || 'Unknown';
  
  const homeRecord = home.records?.find((r: any) => r.type === 'total');
  const awayRecord = away.records?.find((r: any) => r.type === 'total');
  const homeWins = homeRecord?.wins || 0;
  const awayWins = awayRecord?.wins || 0;
  
  const totalWins = homeWins + awayWins;
  const homeProb = totalWins > 0 ? (homeWins / totalWins) * 100 + 5 : 50;
  const adjustedProb = Math.min(75, Math.max(25, homeProb));
  const riskPercentage = 100 - adjustedProb;
  
  return {
    id: `nhl_${event.id}`,
    sport: 'hockey',
    league: 'NHL',
    homeTeam,
    awayTeam,
    date: event.date,
    oddsHome: 1.85,
    oddsAway: 1.85,
    recommendation: adjustedProb > 50 ? homeTeam : awayTeam,
    predictedResult: adjustedProb > 50 ? 'home' : 'away',
    winProbability: Math.round(adjustedProb > 50 ? adjustedProb : 100 - adjustedProb),
    confidence: getConfidenceFromProb(adjustedProb > 50 ? adjustedProb : 100 - adjustedProb),
    riskPercentage: Math.round(riskPercentage),
    riskLevel: getRiskLevel(riskPercentage),
    valueBet: false,
    reasons: [`Match NHL: ${homeTeam} vs ${awayTeam}`, '⚠️ Fallback'],
    warnings: ['Prédiction simplifiée'],
    source: 'espn-fallback',
    modelVersion: 'nhl-simple-v1.0',
    generatedAt: new Date().toISOString(),
  };
}

// ============================================
// UTILITAIRES
// ============================================

function getRiskLevel(riskPercentage: number): 'safe' | 'moderate' | 'risky' {
  if (riskPercentage <= RISK_THRESHOLDS.safe) return 'safe';
  if (riskPercentage <= RISK_THRESHOLDS.moderate) return 'moderate';
  return 'risky';
}

function getConfidenceFromProb(prob: number): 'very_high' | 'high' | 'medium' | 'low' {
  if (prob >= 75) return 'very_high';
  if (prob >= 65) return 'high';
  if (prob >= 55) return 'medium';
  return 'low';
}

function getEndOfDay(): string {
  const end = new Date();
  // ⚠️ Utiliser UTC pour éviter les problèmes de timezone
  end.setUTCHours(23, 59, 59, 999);
  return end.toISOString();
}

function calculateSummary(predictions: DailyPrediction[]): DailyPredictionsFile['summary'] {
  const bySport: Record<string, number> = {};
  const byRisk = { safe: 0, moderate: 0, risky: 0 };
  let valueBets = 0;
  
  for (const p of predictions) {
    bySport[p.sport] = (bySport[p.sport] || 0) + 1;
    byRisk[p.riskLevel]++;
    if (p.valueBet) valueBets++;
  }
  
  return {
    total: predictions.length,
    bySport,
    byRisk,
    valueBets,
  };
}

function saveDailyPredictions(data: DailyPredictionsFile): void {
  if (!fs.existsSync(DATA_DIR)) {
    fs.mkdirSync(DATA_DIR, { recursive: true });
  }
  
  fs.writeFileSync(DAILY_FILE, JSON.stringify(data, null, 2));
  console.log(`💾 Prédictions sauvegardées: ${DAILY_FILE}`);
}

// ============================================
// PERSISTENCE SUPABASE (Vercel-compatible)
// ============================================

/**
 * Sauvegarde les prédictions dans Supabase (persiste entre les fonctions Vercel)
 * Appelé par le cron generate-daily à 05:30 UTC
 */
export async function saveDailyPredictionsToDB(predictions: DailyPrediction[]): Promise<{ saved: number; errors: string[] }> {
  const errors: string[] = [];
  let saved = 0;
  
  try {
    const SupabaseStore = (await import('./db-supabase')).default;
    
    const dbPredictions = predictions.map(p => ({
      match_id: p.id,
      home_team: p.homeTeam,
      away_team: p.awayTeam,
      league: p.league || p.tournament || '',
      sport: p.sport as 'football' | 'basketball' | 'hockey' | 'tennis',
      match_date: p.date,
      odds_home: p.oddsHome || 0,
      odds_draw: p.oddsDraw ?? null,
      odds_away: p.oddsAway || 0,
      predicted_result: p.predictedResult as any,
      confidence: p.confidence,
      risk_percentage: p.riskPercentage,
      source: p.source,
      ml_model_version: p.modelVersion,
      status: 'pending' as const,
      features: {
        winProbability: p.winProbability,
        valueBet: p.valueBet,
        valueBetType: p.valueBetType || null,
        expectedValue: p.expectedValue || 0,
        kellyStake: p.kellyStake || 0,
        recommendation: p.recommendation,
        riskLevel: p.riskLevel,
        reasons: p.reasons || [],
      },
    }));
    
    saved = await SupabaseStore.addPredictions(dbPredictions);
    console.log(`🗄️ ${saved} prédictions sauvegardées dans Supabase`);
  } catch (e: any) {
    errors.push(e.message);
    console.error('❌ Erreur sauvegarde Supabase:', e);
  }
  
  return { saved, errors };
}

/**
 * Charge les prédictions depuis Supabase (filtrées: aujourd'hui + demain, hors tennis)
 */
export async function loadDailyPredictionsFromDB(): Promise<DailyPrediction[]> {
  try {
    const SupabaseStore = (await import('./db-supabase')).default;
    const predictions = await SupabaseStore.getPendingPredictions();
    if (!predictions.length) return [];
    
    // Filtrer: matchs d'aujourd'hui et demain uniquement, exclure tennis
    const now = new Date();
    const todayStart = new Date(now);
    todayStart.setUTCHours(0, 0, 0, 0);
    const dayAfterTomorrow = new Date(todayStart);
    dayAfterTomorrow.setDate(dayAfterTomorrow.getDate() + 2);
    
    return predictions
      .filter(p => {
        if (p.sport === 'tennis') return false;
        const matchDate = new Date(p.match_date);
        return matchDate >= todayStart && matchDate < dayAfterTomorrow;
      })
      .map(p => ({
        id: p.match_id,
        sport: p.sport as DailyPrediction['sport'],
        league: p.league,
        homeTeam: p.home_team,
        awayTeam: p.away_team,
        date: p.match_date,
        oddsHome: p.odds_home,
        oddsAway: p.odds_away,
        oddsDraw: p.odds_draw ?? undefined,
        recommendation: p.features?.recommendation || 
          (p.predicted_result === 'home' ? p.home_team : 
           p.predicted_result === 'draw' ? 'Match Nul' : p.away_team),
        predictedResult: (p.predicted_result === 'draw' ? 'draw' : 
          p.predicted_result === 'away' ? 'away' : 'home') as DailyPrediction['predictedResult'],
        winProbability: p.features?.winProbability || (100 - p.risk_percentage),
        confidence: p.confidence,
        riskPercentage: p.risk_percentage,
        riskLevel: (p.risk_percentage <= 30 ? 'safe' : 
          p.risk_percentage <= 50 ? 'moderate' : 'risky') as DailyPrediction['riskLevel'],
        valueBet: p.features?.valueBet || false,
        valueBetType: p.features?.valueBetType,
        expectedValue: p.features?.expectedValue,
        kellyStake: p.features?.kellyStake,
        reasons: p.features?.reasons || [],
        warnings: [],
        source: p.source || 'supabase',
        modelVersion: p.ml_model_version || 'db-v1.0',
        generatedAt: p.created_at || new Date().toISOString(),
      }));
  } catch (e) {
    console.log('⚠️ Supabase indisponible pour lecture:', e);
    return [];
  }
}

/**
 * Mappe le sport DailyPrediction vers le format Telegram
 */
function mapSportForTelegram(sport: string): string {
  switch (sport) {
    case 'football': return 'Foot';
    case 'basketball': return 'Basket';
    case 'hockey': return 'NHL';
    case 'tennis': return 'Tennis';
    default: return sport;
  }
}

/**
 * Convertit DailyPrediction[] au format attendu par les fonctions Telegram
 */
function mapDailyToTelegramFormat(predictions: DailyPrediction[]) {
  return predictions.map(p => ({
    homeTeam: p.homeTeam,
    awayTeam: p.awayTeam,
    sport: mapSportForTelegram(p.sport),
    league: p.league || p.tournament,
    date: p.date,
    recommendation: p.recommendation,
    predictedResult: p.predictedResult,
    confidence: p.confidence,
    riskPercentage: p.riskPercentage,
    winProbability: p.winProbability,
    valueBetDetected: p.valueBet,
    valueBetType: p.valueBetType,
    oddsHome: p.oddsHome,
    oddsAway: p.oddsAway,
    oddsDraw: p.oddsDraw,
  }));
}

/**
 * Charge les prédictions pour Telegram depuis toutes les sources disponibles
 * Ordre de priorité:
 * 1. Fichier local daily-predictions.json (dev/local)
 * 2. Supabase (Vercel - persiste entre fonctions)
 * 3. ESPN direct (fallback basique - SANS ML)
 */
export async function loadPredictionsForTelegram(): Promise<{
  predictions: Array<{
    homeTeam: string;
    awayTeam: string;
    sport: string;
    league?: string;
    date: string;
    displayDate?: string;
    dateTag?: string;
    recommendation?: string;
    predictedResult?: 'home' | 'away' | 'draw';
    confidence?: string;
    riskPercentage?: number;
    winProbability?: number;
    valueBetDetected?: boolean;
    valueBetType?: string | null;
    oddsHome?: number;
    oddsAway?: number;
    oddsDraw?: number | null;
  }>;
  source: 'file' | 'supabase' | 'espn-fallback';
}> {
  // 1. Essayer le fichier local
  const fileData = loadDailyPredictions();
  if (fileData && fileData.predictions.length > 0) {
    const nonTennis = fileData.predictions.filter(p => p.sport !== 'tennis');
    if (nonTennis.length > 0) {
      console.log(`📦 Source Telegram: fichier local - ${nonTennis.length} prédictions ML`);
      return { predictions: mapDailyToTelegramFormat(nonTennis), source: 'file' };
    }
  }
  
  // 2. Essayer Supabase (source ML fiable sur Vercel)
  const dbPredictions = await loadDailyPredictionsFromDB();
  if (dbPredictions.length > 0) {
    console.log(`🗄️ Source Telegram: Supabase - ${dbPredictions.length} prédictions ML`);
    return { predictions: mapDailyToTelegramFormat(dbPredictions), source: 'supabase' };
  }
  
  // 3. Fallback ESPN direct (calcul basique 1/odd - PAS de ML)
  console.log('📡 Source Telegram: ESPN direct (⚠️ fallback basique sans ML)');
  const { getMatchesWithRealOdds } = await import('./combinedDataService');
  const matches = await getMatchesWithRealOdds();
  
  const predictions = matches
    .filter((m: any) => m.sport?.toLowerCase() !== 'tennis')
    .map((m: any) => ({
      homeTeam: m.homeTeam,
      awayTeam: m.awayTeam,
      sport: m.sport,
      league: m.league,
      date: m.date,
      displayDate: m.displayDate,
      dateTag: m.dateTag,
      recommendation: m.recommendations?.[0]?.label || m.recommendation,
      predictedResult: m.predictedResult || (m.probabilities?.home > m.probabilities?.away ? 'home' : 'away'),
      confidence: m.confidence,
      riskPercentage: m.riskPercentage,
      winProbability: m.winProbability || (m.riskPercentage !== undefined ? 100 - m.riskPercentage : undefined),
      valueBetDetected: m.valueBets?.length > 0,
      valueBetType: m.valueBets?.[0]?.type,
      oddsHome: m.oddsHome,
      oddsAway: m.oddsAway,
      oddsDraw: m.oddsDraw,
    }));
  
  return { predictions, source: 'espn-fallback' };
}

// ============================================
// EXPORTS
// ============================================

export {
  RISK_THRESHOLDS,
  DAILY_FILE,
};
